# ── QAIC Inference Gateway (your-ai-inference-gateway.example.com) ─────────────────────────────
# Step 1: Sign in at https://your-ai-inference-gateway.example.com/login with your your-email email
# Step 2: Go to API Keys → Create API Key → copy the qaic_<prefix>_<secret> value
# Step 3: Paste it below as QAIC_API_KEY

# Your personal API key (format: qaic_<prefix>_<secret>) — generate at your-ai-inference-gateway.example.com
QAIC_API_KEY=

# Shared Apigee token for qualcomm-sparq tenant (same for all participants, from docs)
APIGEE_TOKEN=kHAEOnGs3WCSeRt9Si5xRWvdDi4PbWavoDy27jNTuCkBmWgn

# Gateway base URL (with /api/v1 path per AI Suite docs)
HYDRA_BASE_URL=https://your-inference-gateway.example.com/aips/sparq/api/v1

# Model selection (live model IDs from /api/v1/models)
# Available: qwen3_vl_32b_instruct, gpt-oss-20b, bge-m3, openai/whisper-large-v3-turbo, stabilityai-sdxl-turbo
MODEL_AGENT5=qwen3_vl_32b_instruct
MODEL_AGENT6=gpt-oss-20b
MODEL_EMBED=bge-m3
MODEL_STT=openai/whisper-large-v3-turbo

# ── QGenie fallback (testing without VPN / when AIC100 is rate-limited) ────────
# Set CLOUD_LLM_ENABLED=true to enable.  Only supports anthropic::claude-4-5-sonnet.
CLOUD_LLM_ENABLED=false
CLOUD_LLM_API_KEY=
CLOUD_LLM_ENDPOINT=https://your-cloud-llm.example.com/v1
CLOUD_LLM_MODEL=anthropic::claude-4-5-sonnet

# ── Agent 4 — Edge LLM (Snapdragon X Elite / SA8775P) ─────────────────────────
# Options: genie | ollama | mock
AGENT4_BACKEND=ollama

# Ollama (easiest local LLM — run: ollama pull qwen2:7b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# Genie SDK path (if AGENT4_BACKEND=genie — download from Qualcomm AI Hub)
QWEN7B_MODEL_PATH=

# ── Local model settings ──────────────────────────────────────────────────────
LOCAL_WHISPER_ENABLED=true
LOCAL_TTS_ENABLED=true
LOCAL_TTS_VOICE=af_heart

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
